# Rename this file to `.env` and fill in your real values.
# NEVER commit the .env file. It's already in .gitignore.

# ===========================================================
# REQUIRED
# ===========================================================

# --- Discord ---
# Create an application at https://discord.com/developers/applications,
# add a Bot, copy the token here.
# IMPORTANT: do NOT enable any Privileged Gateway Intents - we don't need them.
DISCORD_TOKEN=replace-me

# Optional: limit slash command sync to one guild during development
# (syncs in seconds vs. up to 1 hour for global).
DEV_GUILD_ID=

# --- Lavalink (audio engine) ---
# If you run the docker-compose.yml in this repo, the defaults work.
LAVALINK_HOST=127.0.0.1
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass

# --- Bot secret key (for encrypting per-guild library credentials) ---
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If you ever rotate this, every /library setup will need to be re-run.
BOT_SECRET_KEY=replace-me

# --- Jamendo (default music source) ---
# Get a free API key at https://devportal.jamendo.com/
# Free tier: 35,000 requests/month - plenty for normal use.
JAMENDO_CLIENT_ID=replace-me

# ===========================================================
# OPTIONAL
# ===========================================================

# --- Last.fm (used only by /discover similar) ---
# Free key at https://www.last.fm/api/account/create
# If omitted, /discover similar will be disabled but the rest works.
LASTFM_API_KEY=

# --- Bot behavior ---
DEFAULT_VOLUME=60
SKIP_VOTE_RATIO=0.5         # 50% of listeners must vote to skip.
LOG_LEVEL=INFO
